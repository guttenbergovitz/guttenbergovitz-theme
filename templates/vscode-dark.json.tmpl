{
    "name": "Guttenbergovitz",
    "type": "dark",
    "colors": {
        "editor.background": "{{base.bg}}",
        "editor.foreground": "{{semantic.punctuation}}",
        "activityBar.background": "{{base.bg_dark}}",
        "activityBar.foreground": "{{semantic.punctuation}}",
        "activityBarBadge.background": "{{git.deleted}}",
        "sideBar.background": "{{base.bg_dark}}",
        "sideBar.foreground": "{{semantic.punctuation}}",
        "editor.lineHighlightBackground": "{{ui.line_highlight}}",
        "editor.selectionBackground": "{{ui.whitespace}}",
        "editor.selectionHighlightBackground": "{{ui.whitespace}}99",
        "editor.wordHighlightBackground": "{{ui.whitespace}}99",
        "editor.wordHighlightStrongBackground": "{{ui.whitespace}}cc",
        "editorCursor.foreground": "{{semantic.punctuation}}",
        "editorWhitespace.foreground": "{{ui.whitespace}}",
        "editorIndentGuide.background1": "{{ui.line_highlight}}",
        "editorIndentGuide.activeBackground1": "{{ui.whitespace}}",
        "editorLineNumber.foreground": "{{git.untracked}}",
        "editorLineNumber.activeForeground": "{{semantic.punctuation}}",
        "statusBar.background": "{{base.bg_dark}}",
        "statusBar.foreground": "{{semantic.punctuation}}",
        "statusBar.debuggingBackground": "{{git.deleted}}",
        "statusBar.noFolderBackground": "{{base.bg_dark}}",
        "titleBar.activeBackground": "{{base.bg_dark}}",
        "titleBar.activeForeground": "{{semantic.punctuation}}",
        "titleBar.inactiveBackground": "{{base.bg_dark}}",
        "titleBar.inactiveForeground": "{{git.untracked}}",
        "tab.activeBackground": "{{base.bg}}",
        "tab.inactiveBackground": "{{base.bg_dark}}",
        "tab.activeForeground": "{{semantic.punctuation}}",
        "tab.inactiveForeground": "{{git.untracked}}",
        "tab.border": "{{base.bg_dark}}",
        "focusBorder": "{{ui.whitespace}}",
        "terminal.background": "{{base.bg}}",
        "terminal.foreground": "{{semantic.punctuation}}",
        "terminal.ansiBlack": "{{base.bg_dark}}",
        "terminal.ansiBrightBlack": "{{git.untracked}}",
        "terminal.ansiRed": "{{git.deleted}}",
        "terminal.ansiBrightRed": "{{git.deleted}}",
        "terminal.ansiGreen": "{{git.added}}",
        "terminal.ansiBrightGreen": "{{git.added}}",
        "terminal.ansiYellow": "{{git.modified}}",
        "terminal.ansiBrightYellow": "{{git.modified}}",
        "terminal.ansiBlue": "{{git.renamed}}",
        "terminal.ansiBrightBlue": "{{git.renamed}}",
        "terminal.ansiMagenta": "{{git.deleted}}",
        "terminal.ansiBrightMagenta": "{{git.deleted}}",
        "terminal.ansiCyan": "{{git.added}}",
        "terminal.ansiBrightCyan": "{{git.added}}",
        "terminal.ansiWhite": "{{semantic.punctuation}}",
        "terminal.ansiBrightWhite": "{{semantic.punctuation}}",
        "editorWidget.background": "{{base.bg_dark}}",
        "editorWidget.border": "{{ui.whitespace}}",
        "editorSuggestWidget.background": "{{base.bg_dark}}",
        "editorSuggestWidget.border": "{{ui.whitespace}}",
        "editorSuggestWidget.selectedBackground": "{{ui.whitespace}}",
        "panel.background": "{{base.bg_dark}}",
        "panel.border": "{{ui.whitespace}}",
        "panelTitle.activeForeground": "{{semantic.punctuation}}",
        "panelTitle.inactiveForeground": "{{git.untracked}}"
    },
    "tokenColors": [
        {
            "name": "Keywords and Storage",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control",
                "keyword.operator.expression",
                "keyword.operator.new",
                "keyword.operator.wordlike",
                "keyword.other.unit"
            ],
            "settings": {
                "foreground": "{{git.deleted}}"
            }
        },
        {
            "name": "Function declarations and calls",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic",
                "meta.function-call",
                "meta.method-call",
                "meta.function",
                "support.function.console",
                "entity.name.function.method"
            ],
            "settings": {
                "foreground": "{{git.renamed}}"
            }
        },
        {
            "name": "Strings and Constants",
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp",
                "constant.character",
                "constant.other.character",
                "constant.other.symbol"
            ],
            "settings": {
                "foreground": "{{git.added}}"
            }
        },
        {
            "name": "Variables and Parameters",
            "scope": [
                "variable",
                "variable.other",
                "variable.parameter",
                "variable.language",
                "variable.other.readwrite",
                "variable.other.object",
                "variable.other.property",
                "support.variable"
            ],
            "settings": {
                "foreground": "{{semantic.punctuation}}"
            }
        },
        {
            "name": "Types and Classes",
            "scope": [
                "entity.name.type",
                "support.type",
                "entity.name.class",
                "entity.other.inherited-class",
                "support.class",
                "storage.type.built-in",
                "storage.type.primitive"
            ],
            "settings": {
                "foreground": "{{git.modified}}"
            }
        },
        {
            "name": "Properties and Members",
            "scope": [
                "variable.other.property",
                "variable.other.object.property",
                "meta.object-literal.key",
                "support.variable.property",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "{{semantic.punctuation}}"
            }
        },
        {
            "name": "Constants and Numerics",
            "scope": [
                "constant",
                "constant.numeric",
                "constant.language",
                "constant.other",
                "support.constant"
            ],
            "settings": {
                "foreground": "{{git.modified}}"
            }
        },
        {
            "name": "Operators",
            "scope": [
                "keyword.operator",
                "keyword.operator.arithmetic",
                "keyword.operator.comparison",
                "keyword.operator.assignment",
                "keyword.operator.type"
            ],
            "settings": {
                "foreground": "{{git.deleted}}"
            }
        },
        {
            "name": "Punctuation",
            "scope": [
                "punctuation",
                "punctuation.definition",
                "punctuation.separator",
                "punctuation.terminator",
                "meta.brace"
            ],
            "settings": {
                "foreground": "{{semantic.punctuation}}"
            }
        },
        {
            "name": "Comments",
            "scope": [
                "comment",
                "comment.line",
                "comment.block",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "{{git.untracked}}",
                "fontStyle": "italic"
            }
        },
        {
            "name": "HTML/XML Tags",
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "{{git.deleted}}"
            }
        },
        {
            "name": "HTML/XML Attributes",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "{{git.modified}}"
            }
        },
        {
            "name": "Markup Headings",
            "scope": [
                "markup.heading",
                "entity.name.section"
            ],
            "settings": {
                "foreground": "{{git.renamed}}",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup Links",
            "scope": [
                "markup.underline.link",
                "string.other.link"
            ],
            "settings": {
                "foreground": "{{git.added}}"
            }
        }
    ]
}